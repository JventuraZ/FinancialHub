# Finnhub — get your free key at https://finnhub.io/register
# Without a key, the app uses 'demo' mode (limited data)
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Candle data (/stock/candle) is a PREMIUM Finnhub endpoint.
# While true (default), the app serves synthetic candles shaped exactly like the
# premium response, so charts and price-history features work without a paid plan.
# After upgrading your Finnhub plan, set this to false to use the real endpoint.
VITE_USE_MOCK_CANDLES=true

# REST Countries — public API, no key required
# Override only if using a self-hosted or alternative endpoint
VITE_COUNTRIES_API_URL=https://restcountries.com/v3.1
